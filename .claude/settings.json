{
  "permissions": {
    "allow": [
      // 基本操作
      "WebFetch(domain:*",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(ls:*)"
    ],
    "deny": [
     // git系のコマンドは誤操作が怖いので一旦全て拒否
     "Bash(git add:*)",
     "Bash(git commit:*)",
     "Bash(git push:*)",
     "Bash(git reset:*)",
     "Bash(git rebase:*)"
   ]
  }
}

{
  "realm": "momiji",
  "enabled": true,
  "sslRequired": "none",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": true,
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": true,
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@momiji.local",
    "fromDisplayName": "momiji (local)",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "clients": [
    {
      "clientId": "momiji-frontend",
      "enabled": true,
      "publicClient": false,
      "secret": "momiji-frontend-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/api/auth/callback/keycloak",
        "http://localhost:3000"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "momiji-api",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:9090/*",
        "https://oauth.pstmn.io/v1/callback"
      ],
      "webOrigins": [
        "http://localhost:9090",
        "https://oauth.pstmn.io"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ]
}
